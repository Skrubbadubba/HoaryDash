{{define "centered-layout"}}
    {{if once "centered-layout-style"}}
<style>
    .main-container {
        display: flex;
        -webkit-display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        height: 100%;
        width: 100%;
        padding: 1.5em 0 3em 0;
    }
    .center-container {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        justify-content: space-between;
        width: 90%;
        margin-bottom: 1em;
    }
    .center-container > div {
        margin: 0 2rem 0 2rem;
    }
</style>
{{end}}
<div class="main-container">
    {{if .Screen.Entities}}
        {{template "entities" (dict
            "Theme" .Theme
            "Screen" .Screen
        )}}
    {{else}}
        {{/* Take up space inside flexbox */}}
        <div style="display: hidden;"></div>
    {{end}}
    <div class="center-container" style="order: {{.Order.Widgets}}">
        {{if enabledByDefault .Screen.Dateclock.Enabled}}
            {{template "dateclock-style" .Theme}}
            {{template "dateclock" (dict
            "Localization" .Config.Localization
            "Dateclock" .Screen.Dateclock
            )}}
        {{end}}
        {{if .Screen.Widgets}}
            {{template "widgets" (dict
            "Theme" .Theme
            "Screen" .Screen
        )}}
        {{end}}
    </div>
    {{if .Screen.Sensors}}
        {{template "sensors" (dict
            "Theme" .Theme
            "Screen" .Screen
        )}}
    {{else}}
        {{/* Take up space inside flexbox */}}
        <div style="display: hidden;"></div>
    {{end}}
</div>
{{end}}