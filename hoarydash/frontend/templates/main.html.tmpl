<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <script>
        (function(){
        var locale = '{{.Config.Localization.Locale}}' || navigator.language || 'en-US';
        var timezone = '{{.Config.Localization.Timezone}}' || Intl.DateTimeFormat().resolvedOptions().timeZone;
        window.CONFIG = {
            fullyKiosk: {
                screensaverTimeout: {{.Config.FullyKiosk.ScreensaverTimeout}}
            },
            entity_ids: [
                {{range .Dashboard.Screens}}
                    {{range .Sensors}}"{{.EntityID}}",{{end}}
                    {{range .Entities}}"{{.EntityID}}",{{end}}
                    {{range .Widgets}}"{{.EntityID}}",{{end}}  
                {{end}}
                ],
            locale: locale,
            timezone: timezone,
            widgetPollInterval: 10 * 60 * 1000,
            };
        window.goFetch = function(path, callback) {
            var xhr = new XMLHttpRequest();
            xhr.open('GET', path, true);
            xhr.onreadystatechange = function() {
                if (xhr.readyState !== 4) { return; }
                if (xhr.status === 200) {
                    try { callback(null, JSON.parse(xhr.responseText)); }
                    catch(e) { callback(e, null); }
                } else {
                    callback(new Error('HTTP ' + xhr.status), null);
                }
            };
            xhr.send();
        };
        }());
    </script>
    {{template "websocket"}}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/hammer.js/2.0.8/hammer.min.js"></script>
    </head>
<body>
    {{if .IsDev}}
        {{template "isdev"}}
    {{end}}
    <div class="screens">
    {{$config := .Config}}
    {{$theme := .Dashboard.Theme}}
    {{template "base-style" .}}
    {{template "btn-style" $theme}}
    <style>
        .screens {
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-orient: horizontal;
            -webkit-box-direction: normal;
            -webkit-flex-direction: row;
            flex-direction: row;
            width: 100%;
            height: 100%;
            overflow-x: hidden;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            {{if enabledByDefault .Dashboard.Animations}}
            scroll-behavior: smooth;
            {{end}}
        }

        .screens::-webkit-scrollbar {
            display: none;
        }

        .screen {
            position: relative;
            -webkit-flex-shrink: 0;
            -webkit-box-flex: 0;
            flex-shrink: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        .main-container {
            display: flex;
            -webkit-display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            height: 100%;
            width: 100%;
            padding: 1.5em 0 3em 0;
        }
        .center-container {
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-align: center;
            -webkit-align-items: center;
            align-items: center;
            justify-content: space-between;
            width: 90%;
            margin-bottom: 1em;
        }
        .center-container > div {
            margin: 0 2rem 0 2rem;
        }
        {{$showHints := enabledByDefault .Dashboard.ShowHints}}
        {{if $showHints}}
        .swipe-hint {
            position: absolute;
            top: 50%;
            -webkit-transform: translateY(-50%);
            transform: translateY(-50%);
            font-size: 1.5em;
            opacity: 0.2;
            display: -webkit-box;
            display: -webkit-flex;
            display: flex;
            -webkit-box-orient: horizontal;
            -webkit-box-direction: normal;
            -webkit-flex-direction: row;
            flex-direction: row;
            -webkit-box-align: center;
            -webkit-align-items: center;
            align-items: center;
        }
        .swipe-hint.left {
            left: 0.1em;
        }
        .swipe-hint.right {
            right: 0.11em;
        }
        {{end}}
    </style>
    {{$extraPad := ""}}
    {{if .Dashboard.Navbar.Enabled}}
        {{if eq .Dashboard.Navbar.Position "bottom"}}{{$extraPad = "padding-bottom: 5.5em;"}}{{end}}
        {{if eq .Dashboard.Navbar.Position "top"}}{{$extraPad = "padding-top: 6em;"}}{{end}}
        {{if eq .Dashboard.Navbar.Position "left"}}{{$extraPad = "padding-left: 2.5em;"}}{{end}}
        {{if eq .Dashboard.Navbar.Position "right"}}{{$extraPad = "padding-right: 2.5em;"}}{{end}}
    {{end}}
    <script>
        function component(script) {
            var root = document.currentScript.previousElementSibling;
            script(root);
        };
    </script>
    {{range $i, $screen := .Dashboard.Screens}}
        <div id="screen-{{.Name}}-container" class="screen" style="order: {{.Position}};">
            {{if $showHints}}
            {{with prevScreen $.Dashboard $i}}
                <div class="swipe-hint left">
                    {{icon "chevron-left"}}
                    {{if .Icon}}{{icon .Icon}}{{end}}
                </div>
            {{end}}
            {{end}}
            {{/* <p>{{json .}}</p> */}}
            <div class="main-container" style="{{css $extraPad}}">
                {{if .Entities}}
                    {{template "entities" (dict
                        "Theme" $theme
                        "Screen" $screen
                    )}}
                {{else}}
                    {{/* Take up space inside flexbox */}}
                    <div style="display: hidden;"></div>
                {{end}}
                
                
                <div class="center-container" style="order: {{.Order.Widgets}}">
                    {{if enabledByDefault .Dateclock.Enabled}}
                        {{template "dateclock-style" $theme}}
                        {{template "dateclock" (dict
                        "Localization" $config.Localization
                        "Dateclock" .Dateclock
                        )}}
                    {{end}}
                    {{if .Widgets}}
                        {{template "widgets" (dict
                        "Theme" $theme
                        "Screen" $screen
                    )}}
                    {{end}}
                
                </div>
                {{if .Sensors}}
                    {{template "sensors" (dict
                        "Theme" $theme
                        "Screen" $screen
                    )}}
                {{else}}
                    {{/* Take up space inside flexbox */}}
                    <div style="display: hidden;"></div>
                {{end}}
                {{if $showHints}}
                {{with nextScreen $.Dashboard $i}}
                <div class="swipe-hint right">
                    {{if .Icon}}{{icon .Icon}}{{end}}
                    {{icon "chevron-right"}}
                </div>
                {{end}}
            </div>
        {{end}}
        </div>
    {{end}}

    {{if .Dashboard.Navbar.Enabled}}
        {{$orientation := "horizontal"}}
        {{if or (eq .Dashboard.Navbar.Position "left") (eq .Dashboard.Navbar.Position "right")}}
            {{$orientation = "vertical"}}
        {{end}}

        <style>
            .navbar-container {
                position: absolute;
                z-index: 5;
            }
            .navbar-container.navbar-bottom {
                bottom: 1em;
                left: 50%;
                -webkit-transform: translateX(-50%);
                transform: translateX(-50%);
            }
            .navbar-container.navbar-top {
                top: 1em;
                left: 50%;
                -webkit-transform: translateX(-50%);
                transform: translateX(-50%);
            }
            .navbar-container.navbar-left {
                left: 1em;
                top: 50%;
                -webkit-transform: translateY(-50%);
                transform: translateY(-50%);
            }
            .navbar-container.navbar-right {
                right: 1em;
                top: 50%;
                -webkit-transform: translateY(-50%);
                transform: translateY(-50%);
            }
            .navbar-container.navbar-horizontal > nav {
                -webkit-flex-direction: row;
                flex-direction: row;
            }
            .navbar-container.navbar-vertical > nav{
                -webkit-flex-direction: column;
                flex-direction: column;
            }
        </style>
        <div class="navbar-container navbar-{{.Dashboard.Navbar.Position | default "bottom"}} navbar-{{$orientation}}">
            {{template "navbar" .Dashboard.Screens}}
            {{if eq .Dashboard.Navbar.Style "rectangle"}}
                {{template "navbar-rectangle-style" (merge .Dashboard.Theme .Dashboard.Navbar)}}
            {{else}}
                {{template "navbar-default-style" .Dashboard.Theme}}
            {{end}}
        </div>
    {{end}}
    </div>
    <script>
    (function() {
        var container = document.querySelector('.screens');
        var currentIndex = 0;

        window.navigateTo = function(index) {
            var screens = container.querySelectorAll('.screen');
            if (index < 0 || index >= screens.length) { return; }
            currentIndex = index;
            container.scrollLeft = index * container.offsetWidth;
            var items = document.querySelectorAll('.navbar-item');
            for (var i = 0; i < items.length; i++) {
                if (i === index) {
                    items[i].className = 'navbar-item active';
                } else {
                    items[i].className = 'navbar-item';
                }
            }
        };

        {{if enabledByDefault .Dashboard.Swipe}}
        var mc = new Hammer.Manager(container);
        mc.add(new Hammer.Swipe({
            direction: Hammer.DIRECTION_HORIZONTAL,
            threshold: 10,
            velocity: 0.3
        }));
        mc.set({ inputClass: Hammer.MouseInput });
        mc.on('swipeleft swiperight', function(e) {
            if (e.type === 'swipeleft') {
                window.navigateTo(currentIndex + 1);
            } else if (e.type === 'swiperight') {
                window.navigateTo(currentIndex - 1);
            }
        });
        {{end}}
    }());
    </script>


    {{if enabledByDefault .Dashboard.Screenonlock}}
        {{template "screenonlock"}}
    {{end}}
    {{if or (enabledByDefault .Dashboard.Screenonlock) (enabledByDefault .Dashboard.Nightlight.Enabled)}}
    {{template "screenonlock-script" $config}}
    {{end}}
    {{/* <p>{{json .Dashboard.Nightlight}}</p> */}}
    {{if enabledByDefault .Dashboard.Nightlight.Enabled}}
        {{template "nightlight" .}}
    {{end}}
</body>
</html>