<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <script>
        (function(){
        var locale = '{{.Config.Localization.Locale}}' || navigator.language || 'en-US';
        var timezone = '{{.Config.Localization.Timezone}}' || Intl.DateTimeFormat().resolvedOptions().timeZone;
        window.CONFIG = {
            fullyKiosk: {
                screensaverTimeout: {{.Config.FullyKiosk.ScreensaverTimeout}}
            },
            entity_ids: [
                {{range .Dashboard.Screens}}
                    {{range .Sensors}}"{{.EntityID}}",{{end}}
                    {{range .Entities}}"{{.EntityID}}",{{end}}
                    {{range .Widgets}}"{{.EntityID}}",{{end}}  
                {{end}}
                ],
            locale: locale,
            timezone: timezone,
            widgetPollInterval: 10 * 60 * 1000,
            };
        window.goFetch = function(path, callback) {
            var xhr = new XMLHttpRequest();
            xhr.open('GET', path, true);
            xhr.onreadystatechange = function() {
                if (xhr.readyState !== 4) { return; }
                if (xhr.status === 200) {
                    try { callback(null, JSON.parse(xhr.responseText)); }
                    catch(e) { callback(e, null); }
                } else {
                    callback(new Error('HTTP ' + xhr.status), null);
                }
            };
            xhr.send();
        };
        }());
    </script>
    {{template "websocket"}}
    <style>
        * {
            {{if enabledByDefault .Dashboard.Animations}}
            -webkit-transition: color 0.5s ease, background-color 0.5s ease, background 0.5s ease, opacity 0.4s ease, -webkit-transform 0.2s ease, fill 0.4s ease;
            transition: color 0.5s ease, background-color 0.5s ease, background 0.5s ease, opacity 0.4s ease, transform 0.2s ease, fill 0.4s ease;
            {{else}}
            -webkit-transition: none;
            transition: none;
            {{end}}
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }
        button:focus { outline: none; }

        
        .screens {
            overflow: hidden;
        }
        .screen {
            width: 100vw;
            height: 100vh;
        }
        .main-container {
            display: flex;
            -webkit-display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            height: 100%;
            width: 100%;
            padding: 1.5em 0 3em 0;
        }
    </style>
    </head>
<body>
    {{if .IsDev}}
        {{template "isdev"}}
    {{end}}
    <div class="screens">
    {{$config := .Config}}
    {{range .Dashboard.Screens}}
        {{template "base-style" .}}
        {{template "btn-style" .Theme}}
        <style>
            .center-container {
                display: -webkit-box;
                display: -webkit-flex;
                display: flex;
                -webkit-box-align: center;
                -webkit-align-items: center;
                align-items: center;
                justify-content: space-between;
                width: 90%;
                margin-bottom: 1em;
            }
            .center-container > div {
                margin: 0 2rem 0 2rem;
            }
            #screen-{{.Name}}-container .btn .icon {
                font-size: 2em;
            }
        </style>
        <div id="screen-{{.Name}}-container" class="screen">
            {{/* <p>{{json .}}</p> */}}
            <div class="main-container">
                {{if .Entities}}
                    {{template "entities" .}}
                {{else}}
                    {{/* Take up space inside flexbox */}}
                    <div style="display: hidden;"></div>
                {{end}}
                
                
                <div class="center-container" style="order: {{.Order.Widgets}}">
                    {{if enabledByDefault .Dateclock.Enabled}}
                        {{template "dateclock" (dict
                        "Localization" $config.Localization
                        "Dateclock" .Dateclock
                        )}}
                    {{end}}
                    {{if .Widgets}}
                        {{template "widgets" .}}
                    {{end}}
                
                </div>
                {{if .Sensors}}
                    {{template "sensors" .}}
                {{else}}
                    {{/* Take up space inside flexbox */}}
                    <div style="display: hidden;"></div>
                {{end}}
            </div>
        {{template "screenonlock" $config}}
        
        {{if enabledByDefault .Nightlight.Enabled}}
            {{template "nightlight" .}}
        {{end}}
        </div>
    {{end}}
    </div>


</body>
</html>