{{define "navbar-style"}}
<style>
    .navbar {
        position: absolute;
        bottom: 1em;
        left: 50%;
        -webkit-transform: translateX(-50%);
        transform: translateX(-50%);
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-box-direction: normal;
        -webkit-flex-direction: row;
        flex-direction: row;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        z-index: 5;
        background: rgba(0, 0, 0, 0.35);
        border-radius: 2em;
        padding: 0.4em 0.6em;
        -webkit-backdrop-filter: blur(8px);
        backdrop-filter: blur(8px);
        font-size: 1.1em;
    }

    .navbar-item {
        opacity: 0.45;
        padding: 0.5em 0.9em;
        cursor: pointer;
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: vertical;
        -webkit-box-direction: normal;
        -webkit-flex-direction: column;
        flex-direction: column;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        color: {{css .Theme.FontColor}};
        -webkit-transition: opacity 0.2s ease;
        transition: opacity 0.2s ease;
        border-radius: 2em;
        font-size: 0.85em;
    }

    .navbar-item.active {
        opacity: 1;
        background: rgba(255, 255, 255, 0.12);
    }

    .navbar-label {
        font-size: 0.7em;
        margin-top: 0.3em;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        white-space: nowrap;
    }

    .navbar-icon {
        font-size: 1.4em;
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
    }
</style>
{{end}}

{{define "navbar"}}
<nav class="navbar">
    {{range $i, $screen := .Screens}}
    <div class="navbar-item{{if eq $i 0}} active{{end}}" onclick="window.navigateTo({{$i}})">
        <div class="navbar-icon">
            {{if $screen.Icon}}
                {{icon $screen.Icon}}
            {{else}}
                {{icon "circle-medium"}}
            {{end}}
        </div>
        <div class="navbar-label">{{$screen.Name}}</div>
    </div>
    {{end}}
</nav>
<script>
component(function(navbar) {
    var items = navbar.querySelectorAll('.navbar-item');
    var widest = 0;
    for (var i = 0; i < items.length; i++) {
        var w = items[i].offsetWidth;
        if (w > widest) { widest = w; }
    }
    for (var i = 0; i < items.length; i++) {
        items[i].style.minWidth = widest + 'px';
    }
});
</script>
{{end}}