{{ define "_media_widget" }}
<style>
    .media-container {
        overflow: hidden;
        font-family: inherit;
        {{if .Entity.FontSize}}
            font-size: {{.Entity.FontSize}}px;
        {{end}}
    }

    .media-top-row {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-flex-direction: row;
        flex-direction: row;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        padding: 0.5em;
    }

    .media-info {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-flex-direction: row;
        flex-direction: row;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        -webkit-box-flex: 1;
        -webkit-flex: 1;
        flex: 1;
        min-width: 0;
        font-size: 1.3em;
    }

    .media-cover {
        width: 2.8em;
        height: 2.8em;
        -webkit-flex-shrink: 0;
        flex-shrink: 0;
        border-radius: 0.2em;
        background: rgba(255, 255, 255, 0.08);
        overflow: hidden;
        margin-right: 0.6em;
    }

    .media-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .media-cover-placeholder {
        width: 100%;
        height: 100%;
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        -webkit-box-pack: center;
        -webkit-justify-content: center;
        justify-content: center;
        font-size: 1.4em;
    }

    .media-song-info {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: vertical;
        -webkit-flex-direction: column;
        flex-direction: column;
        -webkit-box-pack: center;
        -webkit-justify-content: center;
        justify-content: center;
        min-width: 0;
    }

    .media-song {
        font-size: 0.7em;
        font-weight: 600;

        color: {{ .Theme.FontColor | default "#e0f0ff" }};
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }

    .media-artist {
        font-size: 0.6em;

        color: {{ .Theme.SecondaryFontColor | default "#8899aa"}};
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        margin-top: 0.15em;
    }

    .media-album {
        font-size: 0.55em;

        color: {{.Theme.SecondaryFontColor | default "#8899aa"}};
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        margin-top: 0.1em;
        opacity: 0.7;
    }

    .media-idle {
        font-size: 0.65em;

        color: {{.Theme.SecondaryFontColor | default "#8899aa"}};
        font-style: italic;
    }
    .media-bottom-row {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-flex-direction: row;
        flex-direction: row;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        padding: 0.2em 0.2em;
        justify-content: space-evenly;
        {{if enabledByDefault .Entity.InternalBorders}}
        border-top: 0.05em solid rgba(120, 180, 255, 0.12);
        {{end}}
    }

    .media-play-controls {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-flex-direction: row;
        flex-direction: row;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
        -webkit-flex-shrink: 0;
        flex-shrink: 0;
        margin-left: 0.6em;
    }

    .media-ctrl-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: {{.Theme.FontColor | default "#c0d8f0"}};
        font-size: 1.2em;
        line-height: 1;
        line-height: 1;
        padding-bottom: 0.2em;
        opacity: 0.85;
        -webkit-tap-highlight-color: transparent;
    }

    .media-ctrl-btn:active {
        opacity: 0.5;
    }

    .media-ctrl-btn.media-play-btn {
        font-size: 1.7em;
        padding-left: 0.2em;
        padding-right: 0.2em;
        margin-bottom: -0.2em;
        opacity: 1;
    }


    .media-vol-controls {
        display: -webkit-box;
        display: -webkit-flex;
        display: flex;
        -webkit-box-orient: horizontal;
        -webkit-flex-direction: row;
        flex-direction: row;
        -webkit-box-align: center;
        -webkit-align-items: center;
        align-items: center;
    }
    .media-vol-icon {
        font-size: 0.85em;
        margin-right: 0.4em;

        color: {{.Theme.SecondaryFontColor | default "#8899aa"}};
    }

    .media-vol-slider {
        -webkit-appearance: none;
        -webkit-flex: 1;
        flex: 1;
        height: 0.6em;
        border-radius: 0.2em;
        background: rgba(255, 255, 255, 0.15);
        outline: none;
        cursor: pointer;
    }

    .media-vol-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 1.8em;
        height: 1.8em;
        border-radius: 50%;
        background: {{.Theme.FontColor | default "#949494"}};
        cursor: pointer;
    }

    .media-vol-slider::-moz-range-thumb {
        -webkit-appearance: none;
        width: 1.8em;
        height: 1.8em;
        border-radius: 50%;
        background: {{.Theme.FontColor | default "#949494"}};
        cursor: pointer;
    }
</style>

<div class="media-container card">
    <div class="media-top-row">
        <div class="media-info">
            <div class="media-cover" id="media-cover">
                <div class="media-cover-placeholder" id="media-cover-placeholder">♪</div>
            </div>
            <div class="media-song-info" id="media-song-info">
                <span class="media-idle" id="media-idle">Idle</span>
            </div>
        </div>
    </div>
    <div class="media-bottom-row" id="media-volume-row">
        {{ if enabledByDefault .ShowVolume }}
        <div class="media-vol-controls">
            <span class="media-vol-icon">🔈</span>
            <input class="media-vol-slider" type="range" min="0" max="1" step="0.02" id="media-vol-slider"
                value="0.5" />
        </div>
        {{ end }}
        <div class="media-play-controls">
            <button class="media-ctrl-btn" id="media-back" title="Previous">⏮</button>
            <button class="media-ctrl-btn media-play-btn" id="media-play" title="Play/Pause">▶</button>
            <button class="media-ctrl-btn" id="media-forward" title="Next">⏭</button>
        </div>
    </div>
</div>

<script>
    (function () {
    var POLL_INTERVAL = 30 * 1000;
    var entityId = {{.Entity.EntityID}}
    if (!entityId) { return; }

    var haUrl = window.CONFIG.haUrl || '';

    var elIdle = document.getElementById('media-idle');
    var elSongInfo = document.getElementById('media-song-info');
    var elCover = document.getElementById('media-cover');
    var elPlaceholder = document.getElementById('media-cover-placeholder');
    var elPlay = document.getElementById('media-play');
    var elBack = document.getElementById('media-back');
    var elForward = document.getElementById('media-forward');
    var elVolSlider = document.getElementById('media-vol-slider');

    function callService(service) {
        return window.haSend({
            type: 'call_service',
            domain: 'media_player',
            service: service,
            target: { entity_id: entityId }
        });
    }

    function setVolume(vol) {
        return window.haSend({
            type: 'call_service',
            domain: 'media_player',
            service: 'volume_set',
            target: { entity_id: entityId },
            service_data: { volume_level: vol }
        });
    }

    elPlay.onclick = function () { callService('media_play_pause'); };
    elBack.onclick = function () { callService('media_previous_track'); };
    elForward.onclick = function () { callService('media_next_track'); };

    var volDragging = false;

    if (elVolSlider) {
        elVolSlider.ontouchstart = function() { volDragging = true; };
        elVolSlider.onmousedown  = function() { volDragging = true; };
        elVolSlider.ontouchend   = function() { volDragging = false; };
        elVolSlider.onmouseup    = function() { volDragging = false; };

        var volDebounce;

        elVolSlider.oninput = function() {
            volDragging = true;
            clearTimeout(volDebounce);
            var v = parseFloat(elVolSlider.value);
            volDebounce = setTimeout(function() {
                setVolume(v);
                volDragging = false;
            }, 150);
        };
    }

    function getOrCreate(id, tag, className) {
        var el = document.getElementById(id);
        if (!el) {
            el = document.createElement(tag);
            el.id = id;
            if (className) { el.className = className; }
            elSongInfo.appendChild(el);
        }
        return el;
    }

    function renderIdle() {
        elSongInfo.innerHTML = '';
        var idle = document.createElement('span');
        idle.className = 'media-idle';
        idle.textContent = 'Idle';
        elSongInfo.appendChild(idle);
        elPlay.textContent = '▶';
        if (elCover.querySelector('img')) {
            elCover.removeChild(elCover.querySelector('img'));
        }
        elPlaceholder.style.display = '';
    }

    function renderActive(state, attributes) {
        {{/* console.log("ran renderActive with state and attrs: ", state, attributes) */}}
        elPlay.textContent = (state === 'playing') ? '⏸' : '▶';
        elSongInfo.innerHTML = '';

        var song = attributes.media_title || '';
        var artist = attributes.media_artist || '';
        var album = attributes.media_album_name || '';

        if (!song && !artist) {
            renderIdle();
            return;
        }

        var elSong = document.createElement('span');
        elSong.className = 'media-song';
        elSong.textContent = song || '—';
        elSongInfo.appendChild(elSong);

        if (artist) {
            var elArtist = document.createElement('span');
            elArtist.className = 'media-artist';
            elArtist.textContent = artist;
            elSongInfo.appendChild(elArtist);
        }

        {{ if disabledByDefault .ShowAlbum}}
        if (album) {
            var elAlbum = document.createElement('span');
            elAlbum.className = 'media-album';
            elAlbum.textContent = album;
            elSongInfo.appendChild(elAlbum);
        }
        {{ end }}


        var picPath = attributes.entity_picture;
        var existingImg = elCover.querySelector('img');
        if (picPath) {
            var imgSrc = '/api/media_cover?path=' + encodeURIComponent(picPath);
            if (existingImg) {
                if (existingImg.getAttribute('src') !== imgSrc) {
                    existingImg.setAttribute('src', imgSrc);
                }
            } else {
                var img = document.createElement('img');
                img.setAttribute('src', imgSrc);
                img.setAttribute('alt', '');
                elCover.appendChild(img);
            }
            elPlaceholder.style.display = 'none';
        } else {
            if (existingImg) { elCover.removeChild(existingImg); }
            elPlaceholder.style.display = '';
        }

        if (!volDragging && elVolSlider && attributes.volume_level !== undefined) {
            elVolSlider.value = attributes.volume_level;
        }
    }

    var cachedState = null;
    var cachedAttributes = {};

    function mergeUpdate(state, attributes) {
        if (state !== undefined) { cachedState = state; }
        if (attributes !== undefined) {
            for (var key in attributes) {
                if (attributes.hasOwnProperty(key)) {
                    cachedAttributes[key] = attributes[key];
                }
            }
        }
        if (cachedState !== null) {
            renderCurrent(cachedState, cachedAttributes);
        }
    }

    function renderCurrent(state, attributes) {
        if (state === 'playing' || state === 'paused' || state === 'buffering') {
            renderActive(state, attributes);
        } else {
            renderIdle();
        }
    }

    function fetchCurrent() {
        return window.haSend({ type: 'get_states' }).then(function (result) {
            for (var i = 0; i < result.length; i++) {
                if (result[i].entity_id === entityId) {
                    cachedState = result[i].state;
                    cachedAttributes = result[i].attributes || {};
                    renderCurrent(cachedState, cachedAttributes);
                    return;
                }
            }
        });
    }

    window.entityListeners[entityId] = function (state, attributes) {
        mergeUpdate(state, attributes);
    };

    var MAX_TRIES = 15;
    var tries = 0;
    function tryFetch() {
        if (tries >= MAX_TRIES) {
            setTimeout(function () { tries = 0; tryFetch(); }, 3 * 60 * 1000);
            return;
        }
        if (window.haSocketReady) {
            fetchCurrent().catch(function (err) { console.error('media fetch failed:', err); });
        } else {
            ++tries;
            setTimeout(tryFetch, 1000);
        }
    }

    tryFetch();
}());
</script>
{{ end }}