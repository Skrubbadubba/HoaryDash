{{define "weather-widget"}}
{{if once "weather-widget-style"}}
<style>
  .weather-container {
    overflow: hidden;
    font-family: inherit;
    {{if .Entity.FontSize}}
      font-size: {{.Entity.FontSize}}px;
    {{end}}
  }

  .weather-main {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-align: stretch;
    -webkit-align-items: stretch;
    align-items: stretch;
    padding: 0.7em 0;
    justify-content: center;
  }

  .weather-current {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-align: center;
    -webkit-align-items: center;
    align-items: center;
    -webkit-box-flex: 0;
    -webkit-flex: 0 0 auto;
    flex: 0 0 auto;
  }
  .weather-current > div {
    margin: 0 0.2em 0 0.2em;
  }

  .weather-icon {
    font-size: 1.8em;
    line-height: 1;
  }

  .weather-temp {
    font-size: 1.9em;
    font-weight: 700;
    color: {{.Theme.FontColor | default "#f0e0c0"}};
    line-height: 1;
  }

  .weather-temp-unit {
    font-size: 0.9em;
    font-weight: 400;
    color: {{.Theme.SecondaryFontColor | default "#a08060"}};
  }

  .weather-divider {
    width: 0.05em;
    background: rgba(120, 180, 255, 0.15);
    -webkit-align-self: stretch;
    align-self: stretch;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    margin: 0 0.6em;
  }

  .weather-details {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-orient: vertical;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-box-pack: center;
    -webkit-justify-content: center;
    justify-content: center;
    -webkit-box-flex: 1;
  }

  .weather-details > div {
    margin: 0 0.1em 0 0.1em;
  }

  .weather-condition {
    font-size: 0.65em;
    font-weight: 600;
    color: {{.Theme.SecondaryFontColor | default "#d0c8b8"}};
    text-transform: capitalize;
  }

  .weather-meta {
    font-size: 0.55em;
    color: #8899aa;
  }

  .weather-meta span {
    margin-right: 0.5em;
  }

  .weather-forecast {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    {{if enabledByDefault .Entity.InternalBorders}}
    border-top: 0.05em solid rgba(120, 180, 255, 0.12);
    {{end}}
    overflow: scroll;
  }

  .forecast-day {
    -webkit-box-flex: 1;
    -webkit-flex: 1;
    flex: 1;
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-orient: vertical;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-box-align: center;
    -webkit-align-items: center;
    align-items: center;
    padding: 0.4em;
    {{if enabledByDefault .Entity.InternalBorders}}
    border-right: 0.05em solid rgba(120, 180, 255, 0.1);
    {{end}}
  }


  .forecast-day-name {
    font-size: 0.45em;
    color: #8899aa;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.2em;
  }

  .forecast-day-icon {
    font-size: 0.8em;
    line-height: 1.2;
    margin-bottom: 0.2em;
  }

  .forecast-day-temps {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-align: baseline;
    -webkit-align-items: baseline;
    align-items: baseline;
  }
  .forecast-day-temps {
    margin: 0 0.1em 0 0.1em;
  }

  .forecast-temp-high {
    font-size: 0.55em;
    font-weight: 600;
    color: {{.Theme.FontColor | default "#d0c0a0"}};
  }

  .forecast-temp-low {
    font-size: 0.5em;
    color: #6a7a8a;
  }
</style>
{{end}}
<div class="weather-container card">
  <div class="weather-main">
    <div class="weather-current">
      <div class="weather-icon">🌡️</div>
      <div>
        <span class="weather-temp">--</span><span class="weather-temp-unit">°C</span>
      </div>
    </div>
    <div class="weather-divider"></div>
    <div class="weather-details">
      <div class="weather-condition">Loading...</div>
      <div class="weather-meta">
        <span class="weather-wind"></span>
        <span class="weather-humidity"></span>
        <span class="weather-feels"></span>
      </div>
    </div>
  </div>
  <div class="weather-forecast"></div>
</div>

<script>
component(function(wrapper) {
  var POLL_INTERVAL = 10 * 60 * 1000;
  var entityId = {{.Entity.EntityID}};
  console.log("weather entity id is: ", entityId)
  if (!entityId) { return; }

  var locale   = window.CONFIG.locale   || navigator.language || 'en-US';
  var timezone = window.CONFIG.timezone || Intl.DateTimeFormat().resolvedOptions().timeZone;

  var conditionIcons = {
    'clear-night':     '🌙',
    'cloudy':          '☁️',
    'exceptional':     '⚠️',
    'fog':             '🌫️',
    'hail':            '🌨️',
    'lightning':       '⚡',
    'lightning-rainy': '⛈️',
    'partlycloudy':    '⛅',
    'pouring':         '🌧️',
    'rainy':           '🌦️',
    'snowy':           '❄️',
    'snowy-rainy':     '🌨️',
    'sunny':           '☀️',
    'windy':           '🌬️',
    'windy-variant':   '🌬️'
  };

  function iconForCondition(condition) {
    return conditionIcons[condition] || '🌡️';
  }

  function round1(n) {
    return Math.round(parseFloat(n) * 10) / 10;
  }

  function dayNameFromDatetime(datetimeStr) {
    var date = new Date(datetimeStr);
    return date.toLocaleDateString(locale, {
      weekday: 'short',
      timeZone: timezone
    });
  }
  
  function isHourlyForecast(forecasts) {
      if (!forecasts || forecasts.length < 2) { return false; }
      var a = new Date(forecasts[0].datetime);
      var b = new Date(forecasts[1].datetime);
      return a.toDateString() === b.toDateString();
  }

  function formatForecastTime(datetimeStr, hourly) {
      var date = new Date(datetimeStr);
      if (hourly) {
          return date.toLocaleTimeString(locale, {
              hour: '2-digit',
              minute: '2-digit',
              timeZone: timezone,
              hour12: hour12
          });
      }
      return date.toLocaleDateString(locale, {
          weekday: 'short',
          timeZone: timezone
      });
  }

  function renderCurrent(state, attributes) {
    var condLabel = translations[state] || (state || '').replace(/-/g, ' ');
    wrapper.querySelector('.weather-icon').textContent      = iconForCondition(state);
    wrapper.querySelector('.weather-temp').textContent      = round1(attributes.temperature || 0);
    wrapper.querySelector('.weather-condition').textContent = condLabel;
    wrapper.querySelector('.weather-wind').textContent      = attributes.wind_speed
      ? '💨 ' + attributes.wind_speed + ' ' + (attributes.wind_speed_unit || 'm/s')
      : '';
    wrapper.querySelector('.weather-humidity').textContent  = attributes.humidity
      ? '💧 ' + attributes.humidity + '%'
      : '';
    wrapper.querySelector('.weather-feels').textContent     = attributes.apparent_temperature
      ? 'Feels ' + round1(attributes.apparent_temperature) + '°'
      : '';
  }

  function renderForecast(forecast) {
    var container = wrapper.querySelector('.weather-forecast');
    if (!forecast || !forecast.length) {
      container.style.display = 'none';
      return;
    }
    var html = '';
    var days = forecast.slice(0, {{.Entity.ForecastTimes | default 3}});
    var hourly = isHourlyForecast(forecast);
    for (var i = 0; i < days.length; i++) {
      var day       = days[i];
      var dayName   = dayNameFromDatetime(day.datetime);
      var timeLabel = formatForecastTime(day.datetime, hourly);
      var icon      = iconForCondition(day.condition);
      var high      = day.temperature !== undefined ? Math.round(day.temperature) + '°' : '--';
      var low       = day.templow     !== undefined ? Math.round(day.templow)     + '°' : '';
      html += '<div class="forecast-day">'
        + '<div class="forecast-day-name">'  + timeLabel + '</div>'
        + '<div class="forecast-day-icon">'  + icon    + '</div>'
        + '<div class="forecast-day-temps">'
        +   '<span class="forecast-temp-high">' + high + '</span>'
        +   (low ? '<span class="forecast-temp-low">' + low + '</span>' : '')
        + '</div>'
        + '</div>';
    }
    container.innerHTML = html;
  }

  var translations = {};

  function fetchTranslations(callback) {
      window.goFetch('/api/translations/weather/' + window.CONFIG.locale.split("-")[0], function(err, t) {
          if (!err) { translations = t; }
          callback();
      });
  }

  function fetchForecast() {
    return window.haSend({
      type: 'call_service',
      domain: 'weather',
      service: 'get_forecasts',
      service_data: { type: {{.ForecastInterval | default "daily"}} },
      target: { entity_id: entityId },
      return_response: true
    }).then(function(result) {
      var forecasts = result.response
        && result.response[entityId]
        && result.response[entityId].forecast;
      renderForecast(forecasts || []);
    });
  }

  var MAX_TRIES = 15;
  var tries = 0;
  function tryFetch() {
    {{/* console.log("ran tryFetch") */}}
    if (tries >= MAX_TRIES) {
        {{/* console.log("max tries reached, cooling down") */}}
        setTimeout(function() {tries = 0; tryFetch()}, 3 * 60 * 1000)
        return;
    }
    if (window.haSocketReady) {
      fetchTranslations(function(translations) {
            window.weatherTranslations = translations;
            fetchForecast();
        });
        {{/* console.log("tried running fetchWeather") */}}
    } else {
        ++tries;
        setTimeout(tryFetch, 1000);
    }
  }

  window.entityListeners[entityId].push(function(state, attributes) {
      if (state !== undefined) { renderCurrent(state, attributes); }
  });

  window.onHaReady.push(function() {
      fetchTranslations(function() {
          fetchForecast();
          setInterval(fetchForecast, POLL_INTERVAL);
      });
  });

  tryFetch();
});
</script>
{{end}}