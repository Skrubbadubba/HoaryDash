{{define "dateclock-style"}}
<style>
    .dateclock-container {
        z-index: 20;
        display: -webkit-flex;
        display: flex;
        -webkit-flex-direction: column;
        flex-direction: column;
        -webkit-align-items: center;
        align-items: center;
        pointer-events: none;
    }
    .clock {
        font-size: calc(8vw + 1em);
        font-weight: 600;
        margin-bottom: 0rem;
        letter-spacing: -0.02em;
        min-width: 6ch;
        text-align: center;
    }

    .date {
        font-size: calc(2vw + 1em);
        font-weight: 600;
    }
</style>
{{end}}
{{define "dateclock"}}
<div class="dateclock-container">
    <div class="clock"></div>
    <div class="date"></div>
</div>
<script>
    component(function(root) {
    var clockEl = root.querySelector(".clock")
    var dateEl = root.querySelector(".date")

    var locale = window.CONFIG.locale;
    var timezone = window.CONFIG.timezone;
    var hour12 = {{if .Dateclock.Hour12}}true{{else}}false{{end}};

    function updateTime() {
        var now = new Date();

        var time = now.toLocaleTimeString(locale, {
            hour: '2-digit',
            minute: '2-digit',
            {{if .Dateclock.ShowSeconds}}
                second: '2-digit',
            {{end}}
            hour12: hour12,
            timeZone: timezone
        });

        var day = now.toLocaleDateString(locale, {
            weekday: 'long',
            timeZone: timezone
        });

        var date = now.toLocaleDateString(locale, {
            dateStyle: 'short',
            timeZone: timezone
        });
        {{if .Dateclock.CapitaliseDay}}
        day = day.charAt(0).toUpperCase() + day.slice(1);
        {{end}}
        var date = now.toLocaleDateString(locale);

        clockEl.textContent = time;
        dateEl.textContent = day + ', ' + date;
    }

    setInterval(updateTime, 1000);
    updateTime();
    });
</script>
{{end}}