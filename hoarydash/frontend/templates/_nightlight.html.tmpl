{{define "nightlight"}}
<style>
    #nightlight-btn {
        position: fixed;
        transform: translateZ(0);
        bottom: 24px;
        right: 24px;
        {{if not .Nightlight.OverrideColors}}
        background-color: #cc2200;
        {{end}}
    }
    #nightlight-btn svg {
        font-size: 1.1em;
        {{if not .Nightlight.OverrideColors}}
        fill: rgba(255,255,255,0.85);
        {{end}}
    }
    #nightlight-btn.active {
        box-shadow: 0 0 24px rgba(255, 100, 0, 0.2);
    }
    
    #nightlight-btn.active svg { fill: #ff9944; }

    #brightness-panel {
        position: fixed;
        bottom: 90px;
        right: 24px;
        width: 60px;
        {{if .Nightlight.OverrideColors}}
            background-color: {{.Theme.ButtonBackground | default "#333" | css}};
        {{else}}
            background-color: #333;
        {{end}}
        border-radius: 26px;
        padding: 16px 0;
        display: -webkit-flex;
        display: flex;
        -webkit-flex-direction: column;
        flex-direction: column;
        -webkit-align-items: center;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        -webkit-transform: translateY(12px);
        transform: translateY(12px);
        z-index: 50;
    }
    
    #brightness-panel.visible {
        opacity: 1;
        pointer-events: all;
        -webkit-transform: translateY(0);
        transform: translateY(0);
    }
    #custom-slider {
        position: relative;
        width: 22px;
        height: 140px;
        background-color: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
        cursor: pointer;
        touch-action: none;
    }
    #slider-fill {
        position: absolute;
        bottom: 0; left: 0;
        width: 100%;
        height: 80%;
        background-color: #ff6600;
        border-radius: 10px;
        pointer-events: none;
    }
    #slider-thumb {
        position: absolute;
        bottom: 80%;
        left: 50%;
        -webkit-transform: translate(-50%, 50%);
        transform: translate(-50%, 50%);
        width: 34px;
        height: 34px;
        background-color: #ffffff;
        border-radius: 50%;
        box-shadow: 0 2px 6px rgba(0,0,0,0.4);
        pointer-events: none;
    }

    .nightlight-overlay {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
        opacity: 0;
    }
    .nightlight-overlay.dark {
        z-index: 11;
        background-color: #000000;
    }
    .nightlight-overlay.bright {
        opacity: 0;
        z-index: 10;
        background-color: {{.Nightlight.Color | default "hsl(22, 100%, 55%)" | css}};
    }
    {{/* body.nightlight #dateclock-container {
        color: hsla(22, 100%, 35%, 0.5) !important;
    } */}}
    body.nightlight #brightness-panel {
        background-color: #333;
    }
    body.nightlight .btn {
        background-color: #333;
    }
</style>

<div class="nightlight-overlay bright" id="overlay-bright"></div>
<div class="nightlight-overlay dark" id="overlay-dark"></div>
<div id="brightness-panel">
    <div id="custom-slider">
        <div id="slider-fill"></div>
        <div id="slider-thumb"></div>
    </div>
</div>
<button id="nightlight-btn" class="btn" title="Nightlight">
    {{icon "candle"}}
</button>

<script>
    (function() {
    var nightlightActive  = false;
    var btn               = document.getElementById('nightlight-btn');
    var panel             = document.getElementById('brightness-panel');
    var overlayDark       = document.getElementById('overlay-dark');
    var overlayBright     = document.getElementById('overlay-bright');
    var sliderContainer   = document.getElementById('custom-slider');
    var sliderFill        = document.getElementById('slider-fill');
    var sliderThumb       = document.getElementById('slider-thumb');
    var dateclockEl       = document.getElementById('dateclock-container');
    var isDragging        = false;
    var currentBrightness = 80;
    var screensaverWasOn  = false;

    function renderSlider(val) {
        sliderFill.style.height = val + '%';
        sliderThumb.style.bottom = val + '%';
    }
    renderSlider(currentBrightness);

    btn.addEventListener('click', function() {
        nightlightActive = !nightlightActive;
        if (nightlightActive) {
            document.body.className = 'nightlight';
            overlayBright.style.opacity = 1
            btn.classList.add('active');
            panel.className = 'visible';
            applyBrightness(currentBrightness);
            screensaverWasOn = window.screensaverIsOn();
            window.setScreensaverOn();
            } 
        else {
            document.body.className = '';    
            btn.classList.remove('active');
            panel.className = '';
            overlayDark.style.opacity = '0';
            overlayBright.style = null;
            dateclockEl.style = null;
            if (screensaverWasOn) { return; }
            window.setScreensaverOff();
        }
    });

    function applyBrightness(val) {
        var dimAmount = (100 - val) / 100 * 0.92;
        overlayDark.style.opacity = dimAmount;

        var textOpacity = (1-(dimAmount*0.6)) * 0.25;
        dateclockEl.style.opacity = textOpacity;
    }

    function handleDrag(clientY) {
        var rect = sliderContainer.getBoundingClientRect();
        var yOffset = rect.bottom - clientY;
        var percentage = (yOffset / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        currentBrightness = percentage;
        renderSlider(currentBrightness);
        if (nightlightActive) applyBrightness(currentBrightness);
    }

    sliderContainer.addEventListener('mousedown', function(e) { isDragging = true; handleDrag(e.clientY); });
    document.addEventListener('mousemove', function(e) { if (isDragging) handleDrag(e.clientY); });
    document.addEventListener('mouseup', function() { isDragging = false; });
    sliderContainer.addEventListener('touchstart', function(e) { isDragging = true; handleDrag(e.touches[0].clientY); e.preventDefault(); }, false);
    document.addEventListener('touchmove', function(e) { if (isDragging) { handleDrag(e.touches[0].clientY); e.preventDefault(); } }, false);
    document.addEventListener('touchend', function() { isDragging = false; }, false);
    }());
</script>
{{end}}