{{define "nightlight"}}
<style>
    body.nightlight {
        background-color: hsl(22, 100%, 50%);
    }
    body.nightlight .clock,
    body.nightlight .date {
        color: hsla(22, 100%, 35%, 0.5);
    }
    body.nightlight .sensors-container {
        opacity: 0;
    }
    #nightlight-btn {
        position: fixed;
        bottom: 24px;
        right: 24px;
        background-color: #cc2200;
    }
    #nightlight-btn svg {
        width: 26px;
        height: 26px;
        fill: rgba(255,255,255,0.85);
    }
    #nightlight-btn.active {
        background-color: #333;
        box-shadow: 0 0 24px rgba(255, 100, 0, 0.5);
    }
    #nightlight-btn.active svg { fill: #ff9944; }
    #brightness-panel {
        position: fixed;
        bottom: 90px;
        right: 24px;
        width: 52px;
        background-color: rgba(30,30,30,0.9);
        border-radius: 26px;
        padding: 16px 0;
        display: -webkit-flex;
        display: flex;
        -webkit-flex-direction: column;
        flex-direction: column;
        -webkit-align-items: center;
        align-items: center;
        opacity: 0;
        pointer-events: none;
        -webkit-transform: translateY(12px);
        transform: translateY(12px);
        -webkit-transition: opacity 0.4s ease, -webkit-transform 0.4s ease;
        transition: opacity 0.4s ease, transform 0.4s ease;
    }
    #brightness-panel.visible {
        opacity: 1;
        pointer-events: all;
        -webkit-transform: translateY(0);
        transform: translateY(0);
    }
    #custom-slider {
        position: relative;
        width: 20px;
        height: 140px;
        background-color: rgba(255,255,255,0.2);
        border-radius: 10px;
        cursor: pointer;
        touch-action: none;
    }
    #slider-fill {
        position: absolute;
        bottom: 0; left: 0;
        width: 100%;
        height: 80%;
        background-color: #ff6600;
        border-radius: 10px;
        pointer-events: none;
    }
    #slider-thumb {
        position: absolute;
        bottom: 80%;
        left: 50%;
        -webkit-transform: translate(-50%, 50%);
        transform: translate(-50%, 50%);
        width: 32px;
        height: 32px;
        background-color: #ffffff;
        border-radius: 50%;
        box-shadow: 0 2px 6px rgba(0,0,0,0.4);
        pointer-events: none;
    }
    #nightlight-overlay {
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100%;
        background-color: #000000;
        pointer-events: none;
        opacity: 0;
        -webkit-transition: opacity 0.1s linear;
        transition: opacity 0.1s linear;
    }
</style>

<div id="nightlight-overlay"></div>
<div id="brightness-panel">
    <div id="custom-slider">
        <div id="slider-fill"></div>
        <div id="slider-thumb"></div>
    </div>
</div>
<button id="nightlight-btn" class="btn" title="Nightlight">
    <svg fill="#000000" viewBox="-2 -1 24 24" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMinYMin" class="jam jam-candle"><path d="M9 11v6h2v-6H9zm4 6h5a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-1a2 2 0 0 1 2-2h5V9h6v8zM2 19v1h16v-1H2zm8-10.6a3 3 0 0 1-3-3C7 4.295 8 2.495 10 0c2 2.495 3 4.295 3 5.4a3 3 0 0 1-3 3zm0-1.952c.552 0 1-.48 1-1 0-.466-.333-1.109-1-2-.667.891-1 1.534-1 2 0 .52.448 1 1 1z"></path></svg>
</button>

<script>
    var nightlightActive = false;
    var btn = document.getElementById('nightlight-btn');
    var panel = document.getElementById('brightness-panel');
    var overlay = document.getElementById('nightlight-overlay');
    var sliderContainer = document.getElementById('custom-slider');
    var sliderFill = document.getElementById('slider-fill');
    var sliderThumb = document.getElementById('slider-thumb');
    var isDragging = false;
    var currentBrightness = 80;

    function renderSlider(val) {
        sliderFill.style.height = val + '%';
        sliderThumb.style.bottom = val + '%';
    }
    renderSlider(currentBrightness);

    btn.addEventListener('click', function() {
        nightlightActive = !nightlightActive;
        if (nightlightActive) {
            document.body.className = 'nightlight';
            btn.classList.add('active');
            panel.className = 'visible';
            applyBrightness(currentBrightness);
        } else {
            document.body.className = '';
            btn.classList.remove('active');
            panel.className = '';
            overlay.style.opacity = '0';
        }
    });

    function applyBrightness(val) {
        var dimAmount = (100 - val) / 100 * 0.92;
        overlay.style.opacity = dimAmount;
    }

    function handleDrag(clientY) {
        var rect = sliderContainer.getBoundingClientRect();
        var yOffset = rect.bottom - clientY;
        var percentage = (yOffset / rect.height) * 100;
        percentage = Math.max(0, Math.min(100, percentage));
        currentBrightness = percentage;
        renderSlider(currentBrightness);
        if (nightlightActive) applyBrightness(currentBrightness);
    }

    sliderContainer.addEventListener('mousedown', function(e) { isDragging = true; handleDrag(e.clientY); });
    document.addEventListener('mousemove', function(e) { if (isDragging) handleDrag(e.clientY); });
    document.addEventListener('mouseup', function() { isDragging = false; });
    sliderContainer.addEventListener('touchstart', function(e) { isDragging = true; handleDrag(e.touches[0].clientY); e.preventDefault(); }, false);
    document.addEventListener('touchmove', function(e) { if (isDragging) { handleDrag(e.touches[0].clientY); e.preventDefault(); } }, false);
    document.addEventListener('touchend', function() { isDragging = false; }, false);
</script>
{{end}}