{{define "button"}}
<style>
  .ha-button {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    min-width: 80px;
    border-radius: 12px;
    cursor: pointer;
    overflow: visible;
    height: min-content;
  }
  .ha-button-body {
        display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-align-items: center;
    align-items: center;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    padding: 0.4rem 0.75rem;
    gap: 10px;
    background: none;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    width: 100%;
    color: inherit;
    font: inherit;
    -webkit-transition: opacity 0.15s ease, -webkit-transform 0.15s ease;
    transition: opacity 0.15s ease, transform 0.15s ease;
    }
    .ha-button-content {
      display: flex;
      align-items: center;
    }

  .ha-button:active {
    -webkit-transform: scale(0.88);
    transform: scale(0.88);
    opacity: 0.7;
  }

  .ha-button-icon {
    font-size: 1.6rem;
    line-height: 1;
    margin-right: 4px;
  }

  .ha-button-label {
    color: {{.Theme.SecondaryFontColor | default "#ffffff"}};
    {{if not .Theme.SecondaryFontColor}}opacity: 0.6;{{end}}
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .ha-button.pressed {
    opacity: 0.5;
  }
</style>
<div class="ha-button card">
  <button class="ha-button-body" id="ha-btn-{{.Entity.EntityID}}" title="{{.Entity.Label}}">
    <div class="ha-button-content">
    {{if .Entity.Icon}}<span class="ha-button-icon">{{.Entity.Icon}}</span>{{end}}
      <span class="ha-button-label">{{.Entity.Label}}</span>
    </div>
    <div style="height: 36px;"></div>
  </button>
</div>
  <script>
  (function() {
    var entityId = '{{.Entity.EntityID}}';
    var domain = entityId.split('.')[0];
    var btn = document.getElementById('ha-btn-' + entityId);

    var toggleOrPressMap = {
        'input_button': 'press',
        'switch': 'toggle',
        'light': 'toggle',
        'input_boolean': 'toggle',
        'button': 'press',
        'scene': 'turn_on',
        'script': 'turn_on'
    }

    btn.addEventListener('click', function() {
      btn.classList.add('pressed');
      setTimeout(function() { btn.classList.remove('pressed'); }, 300);
    
      window.haSend({
        type: 'call_service',
        domain: domain,
        service: toggleOrPressMap[domain],
        target: { entity_id: entityId }
      });
    });
  })();
  </script>
{{end}}