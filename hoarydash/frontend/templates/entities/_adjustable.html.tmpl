{{define "adjustable"}}
<style>
  .ha-adjustable {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    min-width: 5em;
    overflow: visible;
    position: relative;
    height: min-content;
  }

  .ha-adjustable-body {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-align-items: center;
    align-items: center;
    -webkit-justify-content: space-between;
    justify-content: space-between;
    padding: 0.4em 0.75em 0.3em 0.75em;
    background: none;
    border: none;
    border-radius: 12px 12px 0 0;
    cursor: pointer;
    width: 100%;
    color: inherit;
    font: inherit;
    -webkit-transition: opacity 0.15s ease, -webkit-transform 0.15s ease;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .ha-adjustable-body:active {
    -webkit-transform: scale(0.95);
    transform: scale(0.95);
    opacity: 0.7;
  }

  .ha-adjustable-left {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-align-items: center;
    align-items: center;
  }

  .ha-adjustable-icon {
    font-size: 1.6em;
    line-height: 1;
    -webkit-transition: opacity 0.2s ease;
    transition: opacity 0.2s ease;
  }
  .ha-adjustable.off .ha-adjustable-icon {
    opacity: 0.38;
  }

  .ha-adjustable-label {
    color: {{.Theme.SecondaryFontColor | default "#ffffff"}};
    {{if not .Theme.SecondaryFontColor}}opacity: 0.6;{{end}}
    font-size: 1em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .ha-adjustable-pill {
    width: 1.25em;
    height: 2.25em;
    border-radius: 0.625em;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.14);
    position: relative;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
    pointer-events: none;
    -webkit-transition: background 0.2s ease, border-color 0.2s ease, -webkit-box-shadow 0.2s ease;
    transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .ha-adjustable-pill::after {
    content: '';
    position: absolute;
    top: 1.1875em;
    left: 0.2em;
    width: 0.75em;
    height: 0.75em;
    border-radius: 50%;
    background: rgba(200,220,240,0.38);
    -webkit-transition: top 0.18s ease, background 0.18s ease;
    transition: top 0.18s ease, background 0.18s ease;
  }
  .ha-adjustable.on .ha-adjustable-pill {
    background: rgba(90,210,120,0.3);
    border-color: rgba(90,220,120,0.52);
    -webkit-box-shadow: 0 0 8px rgba(70,200,100,0.22);
    box-shadow: 0 0 8px rgba(70,200,100,0.22);
  }
  .ha-adjustable.on .ha-adjustable-pill::after {
    top: 0.1875em;
    background: #7ae894;
  }

  /* Chevron strip */
  .ha-adjustable-chevron {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0.1875em 0 0.25em;
    background: none;
    border: none;
    border-top: 0.0625em solid rgba(255,255,255,0.07);
    border-radius: 0 0 0.75em 0.75em;
    cursor: pointer;
    color: rgba(160,200,240,0.28);
    font-size: 0.6875em;
    text-align: center;
    line-height: 1;
    -webkit-transition: color 0.12s ease, background 0.12s ease;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .ha-adjustable-chevron:hover {
    color: rgba(160,200,240,0.65);
    background: rgba(255,255,255,0.04);
  }
  .ha-adjustable-chevron-icon {
    display: inline-block;
    font-style: normal;
    -webkit-transition: -webkit-transform 0.18s ease;
    transition: transform 0.18s ease;
  }
  .ha-adjustable.expanded .ha-adjustable-chevron-icon {
    -webkit-transform: rotate(180deg);
    transform: rotate(180deg);
  }

  /* Overlay */
  .ha-adjustable-overlay {
    display: none;
    position: absolute;
    top: calc(100% + 0.625em);
    left: 50%;
    -webkit-transform: translateX(-50%);
    transform: translateX(-50%);
    background: rgba(7,16,34,0.96);
    border: 0.0625em solid rgba(130,185,255,0.15);
    border-radius: 0.625em;
    padding: 0.8125em 0.9375em 0.6875em;
    z-index: 200;
    -webkit-box-shadow: 0 12px 32px rgba(0,0,0,0.55);
    box-shadow: 0 12px 32px rgba(0,0,0,0.55);
  }
  .ha-adjustable.expanded .ha-adjustable-overlay {
    display: block;
  }
  .ha-adjustable-overlay::before {
    content: '';
    position: absolute;
    top: -0.3125em;
    left: 50%;
    width: 0.5625em;
    height: 0.5625em;
    background: rgba(7,16,34,0.96);
    border-left: 0.0625em solid rgba(130,185,255,0.15);
    border-top: 0.0625em solid rgba(130,185,255,0.15);
    -webkit-transform: translateX(-50%) rotate(45deg);
    transform: translateX(-50%) rotate(45deg);
  }

  .ha-adjustable-overlay-title {
    font-size: 0.5625em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(130,180,230);
    margin-bottom: 0.625em;
  }

  .ha-slider-row {
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    margin-bottom: 0.6em;
  }
  .ha-slider-row:last-child {
    margin-bottom: 0;
  }
  .ha-slider-label {
    font-size: 0.5625em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(130,180,230,1);
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
  }
  .ha-slider-row input[type=range] {
    -webkit-appearance: none;
    -webkit-flex: 1;
    flex: 1;
    height: 0.375em;
    border-radius: 2px;
    background: rgba(100,160,255,0.2);
    outline: none;
    border: none;
    cursor: pointer;
  }
  .ha-slider-row input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 0.75em;
    height: 0.75em;
    border-radius: 50%;
    background: #78b4f0;
    -webkit-box-shadow: 0 0 8px rgba(90,175,255,0.44);
    box-shadow: 0 0 8px rgba(90,175,255,0.44);
    cursor: pointer;
  }
  .ha-slider-val {
    font-size: 0.865em;
    color: #78b4f0;
    text-align: right;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
  }

  /* Hidden until JS confirms the attribute exists */
  .ha-slider-row.hidden {
    display: none;
  }
</style>

<div class="ha-adjustable card off" id="ha-adj-{{.Entity.EntityID}}">

  <button class="ha-adjustable-body" id="ha-adj-btn-{{.Entity.EntityID}}" title="{{.Entity.Label}}">
    <div class="ha-adjustable-left">
      {{if .Entity.Icon}}<span class="ha-adjustable-icon">{{.Entity.Icon}}</span>{{end}}
      <span class="ha-adjustable-label entity-label">{{.Entity.Label}}</span>
    </div>
    <div class="ha-adjustable-pill"></div>
  </button>

  <button class="ha-adjustable-chevron" id="ha-adj-chv-{{.Entity.EntityID}}">
    <i class="ha-adjustable-chevron-icon">&#9660;</i>
  </button>

  <div class="ha-adjustable-overlay">
    <div class="ha-adjustable-overlay-title">{{.Entity.Label}}</div>

    {{$domain := domain .Entity.EntityID}}

    {{if eq $domain "light"}}
    <div class="ha-slider-row" id="ha-adj-dim-{{.Entity.EntityID}}">
      <span class="ha-slider-label" style="width: 4em;">Dim</span>
      <input type="range" min="0" max="255" value="255" id="ha-adj-dim-input-{{.Entity.EntityID}}">
      <span class="ha-slider-val" id="ha-adj-dim-val-{{.Entity.EntityID}}" style="width: 3.375em;">100%</span>
    </div>
    <div class="ha-slider-row hidden" id="ha-adj-cct-{{.Entity.EntityID}}">
      <span class="ha-slider-label" style="width: 4em;">Temp</span>
      <input type="range" min="2700" max="6500" value="4000" id="ha-adj-cct-input-{{.Entity.EntityID}}">
      <span class="ha-slider-val" id="ha-adj-cct-val-{{.Entity.EntityID}}" style="width: 3.375em;">4000K</span>
    </div>
    {{end}}

    {{if eq $domain "fan"}}
    <div class="ha-slider-row" id="ha-adj-speed-{{.Entity.EntityID}}" >
      <span class="ha-slider-label" style="width: 4em;">Speed</span>
      <input type="range" min="0" max="100" value="0" id="ha-adj-speed-input-{{.Entity.EntityID}}">
      <span class="ha-slider-val" id="ha-adj-speed-val-{{.Entity.EntityID}}" style="width: 2.5em;">100%</span>
    </div>
  {{end}}
  </div>

</div>

<script>
(function() {
  var entityId = '{{.Entity.EntityID}}';
  var domain = '{{domain .Entity.EntityID}}';
  var wrapper  = document.getElementById('ha-adj-'     + entityId);
  var btn      = document.getElementById('ha-adj-btn-' + entityId);
  var chevron  = document.getElementById('ha-adj-chv-' + entityId);

  {{if eq $domain "light"}}
  var dimRow   = document.getElementById('ha-adj-dim-'       + entityId);
  var dimInput = document.getElementById('ha-adj-dim-input-' + entityId);
  var dimVal   = document.getElementById('ha-adj-dim-val-'   + entityId);
  var cctRow   = document.getElementById('ha-adj-cct-'       + entityId);
  var cctInput = document.getElementById('ha-adj-cct-input-' + entityId);
  var cctVal   = document.getElementById('ha-adj-cct-val-'   + entityId);
  {{end}}

  {{if eq $domain "fan"}}
  var speedRow   = document.getElementById('ha-adj-speed-'       + entityId);
  var speedInput   = document.getElementById('ha-adj-speed-input-' + entityId);
  var speedVal   = document.getElementById('ha-adj-speed-val-'   + entityId);
  {{end}}

  var first = true;
  /* ── State updates from HA ── */
  window.entityListeners[entityId] = function(state, attributes) {
    console.log("HA update for light: ", attributes, state)
    /* Toggle pill */
    if (state === 'on') {
      wrapper.classList.remove('off');
      wrapper.classList.add('on');
    } 
    else if (state === 'off') {
      wrapper.classList.remove('on');
      wrapper.classList.add('off');
    }

    {{if eq $domain "light"}}
    /* Brightness — HA sends 0-255, display as 0-100% */
    if (attributes.brightness !== undefined && attributes.brightness !== null) {
      var pct = Math.round(attributes.brightness / 255 * 100);
      dimInput.value = attributes.brightness;
      dimVal.textContent = pct + '%';
    }
    
    /* CCT — only show row if attribute is present */
    if (attributes.hasOwnProperty("supported_color_modes")) {
      if (attributes.supported_color_modes.includes("color_temp")) {
        cctRow.classList.remove('hidden');
      }

    }
    var kelvin = null;
    if (attributes.hasOwnProperty("color_temp_kelvin")) {
       kelvin = attributes.color_temp_kelvin;
    }
    if (kelvin !== undefined && kelvin !== null) {
      console.log("kelvin is: ", kelvin)
      cctInput.min   = attributes.min_color_temp_kelvin || 2700;
      cctInput.max   = attributes.max_color_temp_kelvin || 6500;
      cctInput.value = kelvin;
      cctVal.textContent = kelvin + 'K';
      return;
    }

    var mireds = null;
    if (attributes.hasOwnProperty("color_temp_mireds")) {
      mireds = attributes.color_temp_mireds
    }

    if (mireds !== undefined && mireds !== null) {
      kelvin = Math.round(1000000 / attributes.color_temp);
      cctInput.min   = attributes.min_color_temp_kelvin || 2700;
      cctInput.max   = attributes.max_color_temp_kelvin || 6500;
      cctInput.value = kelvin;
      cctVal.textContent = kelvin + 'K';
    }
    {{end}}

    {{if eq $domain "fan"}}
      if (attributes.percentage !== undefined && attributes.percentage !== null) {
        var percentage = attributes.percentage
        speedInput.value = percentage
        speedVal.textContent = percentage + '%';
      }
      if (attributes.percentage_step !== undefined && attributes.percentage_tep !== null) {
        speedInput.step = attributes.percentage_step
      }
    {{end}}
  };

  /* ── Toggle tap ── */
  btn.addEventListener('click', function() {
    window.haSend({
      type: 'call_service',
      domain: domain,
      service: 'toggle',
      target: { entity_id: entityId }
    });
  });

  /* ── Chevron tap ── */
  chevron.addEventListener('click', function(e) {
    e.stopPropagation();
    wrapper.classList.toggle('expanded');
  });

  /* ── Close overlay when clicking outside ── */
  document.addEventListener('click', function(e) {
    if (!wrapper.classList.contains('expanded')) return;
    var el = e.target;
    while (el) {
      if (el === wrapper) return;
      el = el.parentNode;
    }
    wrapper.classList.remove('expanded');
  });

  {{if eq $domain "light"}}
  /* ── Dim slider → HA ── */
  dimInput.addEventListener('change', function() {
    var pct = Math.round(dimInput.value / 255 * 100);
    dimVal.textContent = pct + '%';
    window.haSend({
      type: 'call_service',
      domain: 'light',
      service: 'turn_on',
      target: { entity_id: entityId },
      service_data: { brightness: parseInt(dimInput.value, 10) }
    });
  });
  /* Live display while dragging, send only on release (change) */
  dimInput.addEventListener('input', function() {
    var pct = Math.round(dimInput.value / 255 * 100);
    dimVal.textContent = pct + '%';
  });

  /* ── CCT slider → HA ── */
  cctInput.addEventListener('change', function() {
    var kelvin = parseInt(cctInput.value, 10);
    cctVal.textContent = kelvin + 'K';
    window.haSend({
      type: 'call_service',
      domain: 'light',
      service: 'turn_on',
      target: { entity_id: entityId },
      service_data: { color_temp_kelvin: kelvin }
    });
  });
  cctInput.addEventListener('input', function() {
    cctVal.textContent = parseInt(cctInput.value, 10) + 'K';
  });
  {{end}}

  {{if eq $domain "fan"}}
  speedInput.addEventListener('change', function() {
    var speed = speedInput.value
      speedVal.textContent = speed + '%';
      window.haSend({
        type: 'call_service',
        domain: 'fan',
        service: 'set_percentage',
        target: { entity_id: entityId },
        service_data: { percentage: parseInt(speed, 10) }
      });
    });
    speedInput.addEventListener('input', function() {
      speedVal.textContent = speedInput.value + '%';
    });
  {{end}}

})();
</script>
{{end}}