{{define "adjustable-chevron-style"}}
<style>
  .ha-adjustable-chevron {
    display: block;
    width: 100%;
    padding: 0.1875em 0 0.25em;
    background: none;
    border: none;
    border-top: 0.0625em solid rgba(255,255,255,0.07);
    border-radius: 0 0 0.75em 0.75em;
    cursor: pointer;
    color: rgba(160,200,240,0.28);
    font-size: 0.6875em;
    text-align: center;
    line-height: 1;
    -webkit-transition: color 0.12s ease, background 0.12s ease;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .ha-adjustable-chevron:hover {
    color: rgba(160,200,240,0.65);
    background: rgba(255,255,255,0.04);
  }
  .ha-adjustable-chevron-icon {
    display: inline-block;
    font-style: normal;
    -webkit-transition: -webkit-transform 0.18s ease;
    transition: transform 0.18s ease;
  }
  .ha-adjustable.expanded .ha-adjustable-chevron-icon {
    -webkit-transform: rotate(180deg);
    transform: rotate(180deg);
  }

  .ha-adjustable-overlay {
    display: none;
    position: relative;
    top: 0.625em;
    left: 50%;
    -webkit-transform: translateX(-50%);
    transform: translateX(-50%);
    background: rgba(7,16,34,0.96);
    border: 0.0625em solid rgba(130,185,255,0.15);
    border-radius: 0.625em;
    padding: 0.8125em 0.9375em 0.6875em;
    z-index: 200;
    -webkit-box-shadow: 0 12px 32px rgba(0,0,0,0.55);
    box-shadow: 0 12px 32px rgba(0,0,0,0.55);
    width: fit-content;
    font-size: 1.3em;
  }
  .ha-adjustable.expanded .ha-adjustable-overlay {
    display: block;
  }
  .ha-adjustable-overlay::before {
    content: '';
    position: absolute;
    top: -0.3125em;
    left: 50%;
    width: 0.5625em;
    height: 0.5625em;
    background: rgba(7,16,34,0.96);
    border-left: 0.0625em solid rgba(130,185,255,0.15);
    border-top: 0.0625em solid rgba(130,185,255,0.15);
    -webkit-transform: translateX(-50%) rotate(45deg);
    transform: translateX(-50%) rotate(45deg);
  }

  .ha-adjustable-overlay-title {
    font-size: 0.5625em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(130,180,230);
    margin-bottom: 0.625em;
  }

  .ha-slider-row {
    display: -webkit-flex;
    display: flex;
    -webkit-align-items: center;
    align-items: center;
    margin-bottom: 0.6em;
  }
  .ha-slider-row:last-child {
    margin-bottom: 0;
  }
  .ha-slider-label {
    font-size: 0.5625em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(130,180,230,1);
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
  }
  .ha-slider-row input[type=range] {
    -webkit-appearance: none;
    -webkit-flex: 1;
    flex: 1;
    height: 0.6em;
    border-radius: 2px;
    background: rgba(100,160,255,0.2);
    outline: none;
    border: none;
    cursor: pointer;
    margin: 0 0.75em;
  }
  .ha-slider-row input[type=range]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 1.25em;
    height: 1.25em;
    border-radius: 50%;
    background: #78b4f0;
    -webkit-box-shadow: 0 0 8px rgba(90,175,255,0.44);
    box-shadow: 0 0 8px rgba(90,175,255,0.44);
    cursor: pointer;
  }
  .ha-slider-row input[type=range]::-moz-range-thumb {
    -webkit-appearance: none;
    width: 1.25em;
    height: 1.25em;
    border-radius: 50%;
    background: #78b4f0;
    -webkit-box-shadow: 0 0 8px rgba(90,175,255,0.44);
    box-shadow: 0 0 8px rgba(90,175,255,0.44);
    cursor: pointer;
  }
  .ha-slider-val {
    font-size: 0.865em;
    color: #78b4f0;
    text-align: right;
    -webkit-flex-shrink: 0;
    flex-shrink: 0;
  }

 

  /* Hidden until JS confirms the attribute exists */
  .ha-slider-row.hidden {
    display: none;
  }
</style>
{{end}}
{{define "_adjustable-chevron"}}
<div class="ha-adjustable">
  <button class="ha-adjustable-chevron">
    <i class="ha-adjustable-chevron-icon">&#9660;</i>
  </button>

  <div class="ha-adjustable-overlay">
    <div class="ha-adjustable-overlay-title">{{.Label}}</div>

    {{$domain := domain .EntityID}}

    {{if eq $domain "light"}}
    <div class="ha-slider-row dim">
      <span class="ha-slider-label">Dim</span>
      <input class="ha-slider-input" type="range" min="0" max="255" value="255">
      <span class="ha-slider-val" style="width: 3.375em;">100%</span>
    </div>
    <div class="ha-slider-row cct hidden">
      <span class="ha-slider-label">Temp</span>
      <input class="ha-slider-input" type="range" min="2700" max="6500" value="4000">
      <span class="ha-slider-val" style="width: 3.375em;">4000K</span>
    </div>
    {{end}}

    {{if eq $domain "fan"}}
    <div class="ha-slider-row speed">
      <span class="ha-slider-label">Speed</span>
      <input class="ha-slider-input" type="range" min="0" max="100" value="0" >
      <span class="ha-slider-val" width="0">100%</span>
      <span class="ha-slider-val" style="visibility: hidden;">100%</span>
    </div>
    {{end}}
  </div>
</div>
<script>
component(function(wrapper) {
  var entityId = '{{.EntityID}}';
  var domain = '{{domain .EntityID}}';
  var chevron  = wrapper.querySelector('.ha-adjustable-chevron');
  console.log("wrapper: ", wrapper, "chevron: ", chevron)

  {{if eq $domain "light"}}
  var dimRow   = wrapper.querySelector('.ha-slider-row.dim');
  var dimInput = dimRow.querySelector('.ha-slider-input');
  var dimVal   = dimRow.querySelector('.ha-slider-val');
  var cctRow   = wrapper.querySelector('.ha-slider-row.cct');
  var cctInput = cctRow.querySelector('.ha-slider-input');
  var cctVal   = cctRow.querySelector('.ha-slider-val');
  {{end}}

  {{if eq $domain "fan"}}
  var speedRow   = wrapper.querySelector('.ha-slider-row.speed');
  var speedInput = speedRow.querySelector('.ha-slider-input');
  var speedVal   = speedRow.querySelector('.ha-slider-val');

  // Hard set width to initial value, long values with decimals dont stretch the wrapper
  var speedValInitWidth = speedVal.clientWidth;
  console.log("initial width of speed val: ", speedValInitWidth)
  speedVal.style.width = speedValInitWidth;
  {{end}}


  var first = true;
  window.entityListeners[entityId].push(function(state, attributes) {
    {{if eq $domain "light"}}
    /* Brightness — HA sends 0-255, display as 0-100% */
    if (attributes.brightness !== undefined && attributes.brightness !== null) {
      var pct = Math.round(attributes.brightness / 255 * 100);
      dimInput.value = attributes.brightness;
      dimVal.textContent = pct + '%';
    }
    
    /* CCT — only show row if attribute is present */
    if (attributes.hasOwnProperty("supported_color_modes")) {
      if (attributes.supported_color_modes.includes("color_temp")) {
        cctRow.classList.remove('hidden');
      }

    }
    var kelvin = null;
    if (attributes.hasOwnProperty("color_temp_kelvin")) {
       kelvin = attributes.color_temp_kelvin;
    }
    if (kelvin !== undefined && kelvin !== null) {
      console.log("kelvin is: ", kelvin)
      cctInput.min   = attributes.min_color_temp_kelvin || 2700;
      cctInput.max   = attributes.max_color_temp_kelvin || 6500;
      cctInput.value = kelvin;
      cctVal.textContent = kelvin + 'K';
      return;
    }

    var mireds = null;
    if (attributes.hasOwnProperty("color_temp_mireds")) {
      mireds = attributes.color_temp_mireds
    }

    if (mireds !== undefined && mireds !== null) {
      kelvin = Math.round(1000000 / attributes.color_temp);
      cctInput.min   = attributes.min_color_temp_kelvin || 2700;
      cctInput.max   = attributes.max_color_temp_kelvin || 6500;
      cctInput.value = kelvin;
      cctVal.textContent = kelvin + 'K';
    }
    {{end}}

    {{if eq $domain "fan"}}
      if (attributes.percentage !== undefined && attributes.percentage !== null) {
        var percentage = attributes.percentage
        speedInput.value = percentage
        speedVal.textContent = parseFloat(percentage.toFixed(1)) + '%';
      }
      if (attributes.percentage_step !== undefined && attributes.percentage_tep !== null) {
        speedInput.step = attributes.percentage_step
      }
    {{end}}
  });

  chevron.addEventListener('click', function(e) {
    e.stopPropagation();
    wrapper.classList.toggle('expanded');
  });

  document.addEventListener('click', function(e) {
    if (!wrapper.classList.contains('expanded')) return;
    var el = e.target;
    while (el) {
      if (el === wrapper) return;
      el = el.parentNode;
    }
    wrapper.classList.remove('expanded');
  });

  {{if eq $domain "light"}}
  dimInput.addEventListener('change', function() {
    var pct = Math.round(dimInput.value / 255 * 100);
    dimVal.textContent = pct + '%';
    window.haSend({
      type: 'call_service',
      domain: 'light',
      service: 'turn_on',
      target: { entity_id: entityId },
      service_data: { brightness: parseInt(dimInput.value, 10) }
    });
  });
  
  /* Live display while dragging, send only on release (change) */
  dimInput.addEventListener('input', function() {
    var pct = Math.round(dimInput.value / 255 * 100);
    dimVal.textContent = pct + '%';
  });

  cctInput.addEventListener('change', function() {
    var kelvin = parseInt(cctInput.value, 10);
    cctVal.textContent = kelvin + 'K';
    window.haSend({
      type: 'call_service',
      domain: 'light',
      service: 'turn_on',
      target: { entity_id: entityId },
      service_data: { color_temp_kelvin: kelvin }
    });
  });
  cctInput.addEventListener('input', function() {
    cctVal.textContent = parseInt(cctInput.value, 10) + 'K';
  });
  {{end}}

  {{if eq $domain "fan"}}
  speedInput.addEventListener('change', function() {
      var speed = speedInput.value
      speedVal.textContent = parseFloat(speed).toFixed(1) + '%';
      window.haSend({
        type: 'call_service',
        domain: 'fan',
        service: 'set_percentage',
        target: { entity_id: entityId },
        service_data: { percentage: parseInt(speed, 10) }
      });
    });
    speedInput.addEventListener('input', function() {
      speedVal.textContent = parseFloat(speedInput.value).toFixed(1) + '%';
    });
  {{end}}

});
</script>
{{end}}

{{define "adjustable"}}
  {{template "_toggle-open" .}}
  {{template "_adjustable-chevron" .}}
  </div>
  {{template "_toggle-script" .}}
{{end}}