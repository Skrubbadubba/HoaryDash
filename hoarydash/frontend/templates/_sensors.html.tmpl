{{define "sensors"}}
<style>
  .sensor-widget {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-orient: vertical;
    -webkit-box-direction: normal;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-box-align: center;
    -webkit-align-items: center;
    align-items: center;
    -webkit-box-pack: center;
    -webkit-justify-content: center;
    justify-content: center;
    padding: 1rem;
    border-radius: 12px;
    margin-left: 100px;
  }

  .sensor-label {
    color: {{.Theme.SecondaryFontColor | default "#ffffff"}};
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    {{if not .Theme.SecondaryFontColor}}
    opacity: 0.6;
    {{end}}
    margin-bottom: 0.35rem;
  }

  .sensor-value {
    color: {{.Theme.FontColor | default "#ffffff"}};
    font-size: 1.9rem;
    font-weight: 600;
    line-height: 1;
  }

  .sensor-unit {
    color: {{.Theme.SecondaryFontColor | default "#ffffff"}};
    font-size: 0.85rem;
    {{if not .Theme.SecondaryFontColor}}
    opacity: 0.5;
    {{end}}
    margin-top: 0.25rem;
  }

  #sensors-container {
                display: flex;
                -webkit-transition: opacity 0.8s ease, margin-bottom 0.5s ease;
                transition: opacity 0.8s ease, margin-bottom 0.5s ease;
                bottom: 18%;
                margin-top: 50px;
            }
</style>

<div id="sensors-container">
  {{range .Sensors}}
    <div class="sensor-widget card" id="sensor-{{.EntityID}}">
      <div class="sensor-label">{{.Label}}</div>
      <div class="sensor-value" id="sensor-value-{{.EntityID}}">—</div>
      <div class="sensor-unit">{{.Unit}}</div>
    </div>
    <script>
    (function() {
      var entityId = '{{.EntityID}}';
      var el = document.getElementById('sensor-value-' + entityId);
    
      function update(state) {
        el.textContent = state.state;
      }
    
      if (window.entityState && window.entityState[entityId]) {
        update(window.entityState[entityId]);
      }
    
      document.addEventListener('ha-state-change', function(e) {
            if (e.detail.entity_id === entityId) {
                el.textContent = e.detail.state;
            }
        });
    })();
    </script>
  {{end}}
</div>

<script>
  var sensors = document.getElementById("sensors-container").children
  var firstEl = true
  var widest = 0
  for (var i = 0; i < sensors.length; i+=2)  { // Every other element to skip the script tags
    if (firstEl) {
      sensors[i].style.margin = "0px"
      firstEl = false
    }
    currentWidth = sensors[i].clientWidth
    if (currentWidth > widest) {
      widest = currentWidth
    }
  }
  for (var i = 0; i < sensors.length; i+=2)  {
    sensors[i].style.minWidth = (widest + 2).toString() + "px"
  }
</script>

{{end}}