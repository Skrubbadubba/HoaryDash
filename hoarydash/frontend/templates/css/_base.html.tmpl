{{define "base-style"}}
<style>
    #screen-{{.Name}}-container {
        font-size: {{.Theme.BaseFontSize | default "18"}}px;
        background-color: {{.Theme.BodyBackground | default "#000000" | css}};
        background: {{.Theme.BackgroundGradient}};
        color: {{.Theme.FontColor | default "#ffffff" | css}};
        font-family: "Outfit", sans-serif;
        display: -webkit-flex;
        display: flex;
        -webkit-flex-direction: column;
        flex-direction: column;
        -webkit-justify-content: center;
        justify-content: center;
        -webkit-align-items: center;
        align-items: center;
        height: 100vh;
        overflow: hidden;
    }
    #screen-{{.Name}}-container .card {
        border-radius: {{.Theme.Cards.BorderRadius | default "0.5em"}};
        {{if enabledByDefault .Theme.Cards.Borders}}
        border: 0.125em solid {{.Theme.Cards.BorderColor | default "rgba(130,185,255,0.15)" | css}};
        {{end}}
        background-color: {{.Theme.Cards.Background | default "rgba(18, 18, 18, 0.75)" | css}}
    }
    #screen-{{.Name}}-container .icon {
        height: 1em;
        width: 1em;
        fill: {{.Theme.IconColor | default "#e5e5e5" | css}}
    }
</style>
{{end}}