{{define "btn-style"}}
    <style>
        .btn {
            width: 52px;
            height: 52px;
            background-color: {{.ButtonBackground | default "#1a1a1a" | css}};
            border: none;
            border-radius: 14px;
            cursor: pointer;
            outline: none;
            display: -webkit-flex;
            display: flex;
            -webkit-align-items: center;
            align-items: center;
            -webkit-justify-content: center;
            justify-content: center;
            z-index: 50;
        }
        .btn svg {
            width: 26px;
            height: 26px;
            fill: {{.IconColor | default "rgba(255,255,255,0.4)" | css}};
        }
        .btn:active {
            -webkit-transform: scale(0.88);
            transform: scale(0.88);
        }
    </style>
{{end}}