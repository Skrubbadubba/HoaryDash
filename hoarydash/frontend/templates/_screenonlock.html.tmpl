{{define "screenonlock"}}
<style>
    #screenon-btn {
        position: fixed;
        bottom: 24px;
        left: 24px;
    }

    #screenon-btn.active {
        background-color: #1a3a1a;
    }
    #screenon-btn.active svg {
        fill: #44ff88;
    }
    #screenon-btn:active {
        -webkit-transform: scale(0.88);
        transform: scale(0.88);
    }
</style>

<button id="screenon-btn" class="btn" title="Keep screen on">
    {{icon "eye"}}
</button>

<script>
    (function() {
    var previousTimer = '{{ .FullyKiosk.ScreensaverTimeout }}';
    var screenOnBtn = document.getElementById('screenon-btn');

    function getTimer() {
        if (typeof fully !== 'undefined') {
            return fully.getStringSetting("timeToScreensaverV2");
        }
        return previousTimer;
    }

    function setScreensaverOn() {
        var current = getTimer();
        if (current != 0) { previousTimer = current; }
        if (typeof fully !== 'undefined') {
            fully.setStringSetting("timeToScreensaverV2", 0);
        }
        screenOnBtn.classList.add('active');
    }

    function setScreensaverOff() {
        if (typeof fully !== 'undefined') {
            fully.setStringSetting("timeToScreensaverV2", previousTimer != 0 ? previousTimer : '{{ .FullyKiosk.ScreensaverTimeout }}');
        }
        screenOnBtn.classList.remove('active');
    }

    function isScreenAlwaysOn() {
        return getTimer() == 0;
    }

    screenOnBtn.addEventListener('click', function() {
        if (isScreenAlwaysOn()) {
            setScreensaverOff();
        } else {
            setScreensaverOn();
        }
    });

    if (isScreenAlwaysOn()) {
        screenOnBtn.classList.add('active');
    } else {
        screenOnBtn.classList.remove('active');
    }

    window.setScreensaverOn    = setScreensaverOn;
    window.setScreensaverOff   = setScreensaverOff;
    window.screensaverIsOn     = isScreenAlwaysOn;
    }());
</script>
{{end}}