{{define "buttons"}}
<style>
  #buttons-container {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-wrap: wrap;
    flex-wrap: wrap;
    -webkit-justify-content: center;
    justify-content: center;
    margin: 6px;
    margin-bottom: 24px;
    margin-top: -100px;
  }

  .ha-button {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-align-items: center;
    align-items: center;
    -webkit-justify-content: center;
    justify-content: center;
    margin: 30px;
    padding: 1rem 1.4rem;
    min-width: 80px;
    border-radius: 12px;
    cursor: pointer;
    -webkit-transition: opacity 0.15s ease, -webkit-transform 0.15s ease;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .ha-button:active {
    -webkit-transform: scale(0.88);
    transform: scale(0.88);
    opacity: 0.7;
  }

  .ha-button-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .ha-button-label {
    color: {{.Theme.SecondaryFontColor | default "#ffffff"}};
    {{if not .Theme.SecondaryFontColor}}opacity: 0.6;{{end}}
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .ha-button.pressed {
    opacity: 0.5;
  }
</style>

<div id="buttons-container">
  {{range .Buttons}}
  <button class="ha-button card" id="ha-btn-{{.EntityID}}" title="{{.Label}}">
    {{if .Icon}}<span class="ha-button-icon">{{.Icon}}</span>{{end}}
    <span class="ha-button-label">{{.Label}}</span>
  </button>
  <script>
  (function() {
    var entityId = '{{.EntityID}}';
    var domain = entityId.split('.')[0];
    var btn = document.getElementById('ha-btn-' + entityId);

    var toggleOrPressMap = {
        'input_button': 'press',
        'switch': 'toggle',
        'light': 'toggle',
        'input_boolean': 'toggle',
        'button': 'press'
    }

    btn.addEventListener('click', function() {
      btn.classList.add('pressed');
      setTimeout(function() { btn.classList.remove('pressed'); }, 300);
    
      window.haSend({
        type: 'call_service',
        domain: domain,
        service: toggleOrPressMap[domain],
        target: { entity_id: entityId }
      });
    });
  })();
  </script>
  {{end}}
</div>
{{end}}