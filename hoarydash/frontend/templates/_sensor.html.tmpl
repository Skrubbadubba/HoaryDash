{{define "_sensor-style"}}
{{if once "sensor-style"}}
<style>
  .sensor-card {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-box-align: center;
    -webkit-align-items: center;
    align-items: center;
    -webkit-box-pack: center;
    -webkit-justify-content: center;
    justify-content: center;
    padding: 1em;
    margin: 0.3125em;
    {{template "create-card-theme" .Sensors}}
  }

  .sensor-label {
    color: {{.SecondaryFontColor | default "#ffffff"}};
    font-size: 1em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    {{if not .SecondaryFontColor}}
    opacity: 0.6;
    {{end}}
    margin-bottom: 0.35em;
    
  }

  .sensor-value {
    color: {{.FontColor | default "#ffffff"}};
    font-size: 1.9em;
    font-weight: 600;
    line-height: 1;
  }

  .sensor-unit {
    color: {{.SecondaryFontColor | default "#ffffff"}};
    font-size: 0.85em;
    {{if not .SecondaryFontColor}}
    opacity: 0.5;
    {{end}}
    margin-top: 0.25rem;
  }
</style>
{{end}}
{{end}}

{{define "_sensor"}}
<div class="sensor-card card" id="sensor-{{.EntityID}}">
    <div class="sensor-label">{{.Label}}</div>
    <div class="sensor-value">—</div>
    <div class="sensor-unit">{{.Unit}}</div>
</div>
<script>
component(function(root) {
  var entityId = '{{.EntityID}}';
  var el = root.querySelector('.sensor-value');

  function update(state, attrs) {
    el.textContent = state;
  }

  window.entityListeners[entityId].push(update)
});
</script>
{{end}}

{{define "sensor"}}
  {{template "_sensor-style" .Theme}}
  {{template "_sensor" .Entity}}
{{end}}