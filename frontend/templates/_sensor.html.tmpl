{{define "sensor-styles"}}
<style>
  .sensor-widget {
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    -webkit-box-orient: vertical;
    -webkit-box-direction: normal;
    -webkit-flex-direction: column;
    flex-direction: column;
    -webkit-box-align: center;
    -webkit-align-items: center;
    align-items: center;
    -webkit-box-pack: center;
    -webkit-justify-content: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(255,255,255,0.07);
    border-radius: 12px;
    margin-inline: 12px;
  }

  .sensor-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.6;
    margin-bottom: 0.35rem;
  }

  .sensor-value {
    font-size: 1.8rem;
    font-weight: 600;
    line-height: 1;
  }

  .sensor-unit {
    font-size: 0.85rem;
    opacity: 0.5;
    margin-top: 0.25rem;
  }
</style>
{{end}}

{{define "sensor"}}
<div class="sensor-widget" id="sensor-{{.EntityID}}">
  <div class="sensor-label">{{.Label}}</div>
  <div class="sensor-value" id="sensor-value-{{.EntityID}}">—</div>
  <div class="sensor-unit">{{.Unit}}</div>
</div>

<script>
(function() {
  var entityId = '{{.EntityID}}';
  var el = document.getElementById('sensor-value-' + entityId);

  function update(state) {
    el.textContent = state.state;
  }

  if (window.entityState && window.entityState[entityId]) {
    update(window.entityState[entityId]);
  }

  document.addEventListener('ha-state-change', function(e) {
        if (e.detail.entity_id === entityId) {
            el.textContent = e.detail.state;
        }
    });
})();
</script>
{{end}}