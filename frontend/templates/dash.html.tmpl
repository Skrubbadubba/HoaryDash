<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #000000;
            color: #ffffff;
            font-family: "Outfit", sans-serif;
            display: -webkit-flex;
            display: flex;
            -webkit-flex-direction: column;
            flex-direction: column;
            -webkit-justify-content: center;
            justify-content: center;
            -webkit-align-items: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
            -webkit-transition: background-color 0.8s ease;
            transition: background-color 0.8s ease;
        }

        body.nightlight {
            background-color: hsl(22, 100%, 50%);
        }

        body.nightlight .clock,
        body.nightlight .date {
            color: hsla(22, 100%, 35%, 0.5);
        }

        .clock {
            font-size: 15vw;
            font-weight: 600;
            margin-bottom: 0rem;
            -webkit-transition: color 0.8s ease, margin-bottom 0.5s ease;
            transition: color 0.8s ease, margin-bottom 0.5s ease;
            letter-spacing: -0.02em;
        }

        .date {
            font-size: 4vw;
            font-weight: 600;
            -webkit-transition: color 0.8s ease;
            transition: color 0.8s ease;
        }

        /* ─── Weather widget (top-right, from original) ─── */
        .wlr {
            position: absolute;
            top: 15px;
            right: 20px;
            font-family: "Outfit", sans-serif;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <!-- Weather block -->
    <!-- <div id="id1c055f8167e7f" a='{"t":"r","v":"1.2","lang":"sv","locs":[865],"ssot":"c","sics":"ms","cbkg":"#000000","cfnt":"#FFFFFF","codd":"#000000","cont":"#E0E0E0","stof":"3","sfnt":"a"}'>Weather Data Source: <a href="https://sharpweather.com/weather_linkoping/30_days/">weather forecast Linkoping 30 days</a></div>
    <script async src="https://static1.sharpweather.com/widgetjs/?id=id1c055f8167e7f"></script> -->

    <!-- Clock & Date -->
    <div class="clock" id="clock"></div>
    <div class="date" id="date"></div>

    {{if .Dashboard.Nightlight }}
        {{template "nightlight" .}}
    {{end}}
    <script>
        fetch("/api").then(response => {
            response.json().then(res => alert(JSON.stringify(res)))
            <!-- response.json().then(res => console.log(JSON.stringify(res))) -->
        })
        // ─── Clock ───────────────────────────────────────────
        function updateTime() {
            var now = new Date();
            var hours = now.getHours();
            var minutes = now.getMinutes();

            var days = ['Måndag', 'Tisdag', 'Onsdag', 'Torsdag', 'Fredag', 'Lördag', 'Söndag'];
            // Note: getDay() returns 0=Sunday. Remap for Swedish Monday-first:
            var dayIndex = now.getDay(); // 0=Sun,1=Mon...6=Sat
            var swedishIndex = (dayIndex + 6) % 7; // 0=Mon...6=Sun
            var day = days[swedishIndex];

            var date = now.toLocaleDateString('de-DE');

            var hStr = hours < 10 ? '0' + hours : '' + hours;
            var mStr = minutes < 10 ? '0' + minutes : '' + minutes;

            document.getElementById('clock').innerHTML = hStr + ':' + mStr;
            document.getElementById('date').innerHTML = day + ', ' + date;
        }

        // Margin toggle (screensaver burn-in prevention)
        function toggleClockMargin() {
            var el = document.getElementById('clock');
            el.style.marginBottom = (el.style.marginBottom === '4rem') ? '0rem' : '4rem';
        }

        setInterval(updateTime, 1000);
        setInterval(toggleClockMargin, 5 * 60 * 1000);
        updateTime();
    </script>
</body>
</html>