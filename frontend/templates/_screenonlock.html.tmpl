{{define "screenonlock"}}
<style>
    #screenon-btn {
        position: fixed;
        bottom: 24px;
        left: 24px;
        width: 52px;
        height: 52px;
        background-color: #1a1a1a;
        border: none;
        border-radius: 14px;
        cursor: pointer;
        -webkit-transition: background-color 0.3s ease, -webkit-transform 0.15s ease;
        transition: background-color 0.3s ease, transform 0.15s ease;
        outline: none;
        display: -webkit-flex;
        display: flex;
        -webkit-align-items: center;
        align-items: center;
        -webkit-justify-content: center;
        justify-content: center;
    }
    #screenon-btn svg {
        width: 26px;
        height: 26px;
        fill: rgba(255,255,255,0.4);
        -webkit-transition: fill 0.3s ease;
        transition: fill 0.3s ease;
    }
    #screenon-btn.active {
        background-color: #1a3a1a;
    }
    #screenon-btn.active svg {
        fill: #44ff88;
    }
    #screenon-btn:active {
        -webkit-transform: scale(0.88);
        transform: scale(0.88);
    }
</style>

<button id="screenon-btn" title="Keep screen on">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
    </svg>
</button>

<script>
    var screenOnActive = false;
    var screenOnBtn = document.getElementById('screenon-btn');

    function setScreensaverTimeout(seconds) {
        var password = window.CONFIG.fullyKiosk.password;
        var url = 'http://localhost:2323/?cmd=setStringSetting' +
            '&key=timeToScreensaverV2' +
            '&value=' + seconds +
            '&password=' + encodeURIComponent(password);

        fetch(url, { mode: 'no-cors' }).catch(function(err) {
            console.log('Fully Kiosk call failed: ' + err);
        });
    }

    screenOnBtn.addEventListener('click', function() {
        screenOnActive = !screenOnActive;
        if (screenOnActive) {
            screenOnBtn.className = 'active';
            setScreensaverTimeout(0);
        } else {
            screenOnBtn.className = '';
            setScreensaverTimeout(window.CONFIG.fullyKiosk.screensaverTimeout);
        }
    });
</script>
{{end}}